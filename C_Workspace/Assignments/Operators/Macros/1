#include<stdio.h>
#define Buffer_Size 5
int main()
{
       //Create a macro-BUFFER_SIZE and use it to declare an integer array. Print all elements.//
       int a[Buffer_Size];
	printf("Enter %d values in the array \n",Buffer_Size);
